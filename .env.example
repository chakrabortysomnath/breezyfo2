# Breeze API (ICICI Direct)
BREEZE_API_KEY=your_api_key_here
BREEZE_API_SECRET=your_api_secret_here
BREEZE_SESSION_TOKEN=your_session_token_here

# QuotaGuard Static IP (set by Render add-on automatically)
QUOTAGUARD_URL=socks5://username:password@proxy.quotaguard.com:9293

# Auth (JWT)
JWT_SECRET=your-very-long-random-secret-here
ADMIN_EMAIL=admin@yourdomain.com
GMAIL_SENDER=yourapp@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
BACKEND_URL=https://fo-trading-backend.onrender.com

# App
ENVIRONMENT=production
LOG_LEVEL=INFO
